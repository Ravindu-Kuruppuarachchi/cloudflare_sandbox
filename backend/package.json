{
  "name": "isa-sandbox-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:apply": "wrangler d1 execute isa_sandbox_db --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute isa_sandbox_db --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "typescript": "^5.6.0",
    "wrangler": "^4.90.0"
  }
}
